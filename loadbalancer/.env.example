# Example values: create a `.env` file with appropriate values for your deployment

# The "region" this server should be identified as (FQDN will be ${region}.pkg.julialang.org)
SERVER_REGION=starfleet-central

# The upstream pkgserver instances (host:port, reachable from the host network)
PKGSERVERS="localhost:8001 localhost:8002"

# The list of S3 buckets that should be mirrored under /mirror
S3_MIRROR_BUCKET_LIST="julialang2 julialangnightlies"

# The email that should be given to certbot as the owner of the SSL certificate
CERTBOT_EMAIL=info@foobar.com

# Optional: redirect content-addressed resources to a CDN instead of serving from pkgserver
# CDN_REDIRECT_URL=https://storage.julialang.net

# Disable TLS (listen on port 8000 only, no certbot). Useful for local testing.
# DISABLE_TLS=1
